# Discord Bot Token — create a bot at https://discord.com/developers/applications
# Required permissions: View Channels, Read Message History (guild structure only)
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# The ID of the Discord server to mirror (right-click server → Copy Server ID)
DISCORD_GUILD_ID=your_guild_id_here

# Slack Bot Token — create an app at https://api.slack.com/apps
# Required scopes: channels:manage, channels:write, groups:write
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here
