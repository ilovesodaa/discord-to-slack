# Discord Bot Token — create a bot at https://discord.com/developers/applications
# For migrate.py: Required permissions: View Channels
# For sync_messages.py: Required permissions: Send Messages, Read Message History, Manage Webhooks
#   NOTE: Manage Webhooks is required so the bot can create per-channel "Slack Bridge" webhooks
#         that display Slack users' names and avatars in Discord.
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# The ID of the Discord server to mirror (right-click server → Copy Server ID)
DISCORD_GUILD_ID=your_guild_id_here

# Slack Bot Token — create an app at https://api.slack.com/apps
# For migrate.py: Required scopes: channels:manage, channels:write, groups:write
# For sync_messages.py: Additional scopes: chat:write, users:read, channels:history, groups:history, files:read
#   NOTE: files:read is required to forward files/attachments from Slack to Discord
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here

# Slack App Token — required for sync_messages.py only (Socket Mode)
# Enable Socket Mode in your Slack app settings to get this token
# Also required: Event Subscriptions must be ON with these bot events subscribed:
#   message.channels  (messages in public channels)
#   message.groups    (messages in private channels)
# After adding events, reinstall the app to your workspace.
SLACK_APP_TOKEN=xapp-your-slack-app-token-here
